{$APP_DOMAIN} {
    # Backend API routes
    handle /api/* {
        reverse_proxy backend:8000
    }
    handle /docs {
        reverse_proxy backend:8000
    }
    handle /redoc {
        reverse_proxy backend:8000
    }
    handle /openapi.json {
        reverse_proxy backend:8000
    }

    # Everything else goes to the frontend
    handle {
        reverse_proxy frontend:80
    }
}
